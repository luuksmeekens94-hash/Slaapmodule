{
  "name": "slaapmodule-remotion-poc",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "start": "remotion studio",
    "render:all": "node render-all.mjs",
    "render:cycles":   "remotion render cycles   out/cycles.mp4",
    "render:breathe":  "remotion render breathe  out/breathe.mp4",
    "render:night":    "remotion render night    out/night.mp4",
    "render:clock":    "remotion render clock    out/clock.mp4",
    "render:sun":      "remotion render sun      out/sun.mp4",
    "render:rhythm":   "remotion render rhythm   out/rhythm.mp4",
    "render:pressure": "remotion render pressure out/pressure.mp4",
    "still:cycles":    "remotion still cycles    out/cycles-frame.png   --frame=450",
    "still:breathe":   "remotion still breathe   out/breathe-frame.png  --frame=300",
    "still:night":     "remotion still night     out/night-frame.png    --frame=540",
    "still:clock":     "remotion still clock     out/clock-frame.png    --frame=600",
    "still:sun":       "remotion still sun       out/sun-frame.png      --frame=600",
    "still:rhythm":    "remotion still rhythm    out/rhythm-frame.png   --frame=480",
    "still:pressure":  "remotion still pressure  out/pressure-frame.png --frame=540"
  },
  "dependencies": {
    "@remotion/cli": "4.0.385",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "remotion": "4.0.385"
  },
  "devDependencies": {
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "typescript": "5.6.3"
  }
}
