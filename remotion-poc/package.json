{
  "name": "slaapmodule-remotion-poc",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "start": "remotion studio",
    "render:all": "node render-all.mjs",
    "render:premium": "node render-all.mjs force cycles rhythm",
    "render:force": "node scripts/render-force-production.mjs",
    "generate:series-voices": "python3 scripts/generate-series-voices.py",
    "render:series": "node scripts/render-series-production.mjs",
    "render:cycles": "remotion render cycles   out/cycles.mp4",
    "render:breathe": "remotion render breathe  out/breathe.mp4",
    "render:night": "remotion render night    out/night.mp4",
    "render:clock": "remotion render clock    out/clock.mp4",
    "render:sun": "remotion render sun      out/sun.mp4",
    "render:rhythm": "remotion render rhythm   out/rhythm.mp4",
    "render:pressure": "remotion render pressure out/pressure.mp4",
    "render:force-animatic": "remotion render force-animatic out/force-animatic.mp4",
    "render:force-final": "remotion render force-final out/force-final.mp4",
    "still:force-final": "remotion still force-final out/force-final-frame.png --frame=555",
    "still:force-animatic": "remotion still force-animatic out/force-animatic-frame.png --frame=510",
    "still:premium": "npm run still:force && npm run still:cycles && npm run still:rhythm",
    "still:force": "remotion still force     out/force-frame.png    --frame=520",
    "still:cycles": "remotion still cycles    out/cycles-frame.png   --frame=600",
    "still:breathe": "remotion still breathe   out/breathe-frame.png  --frame=300",
    "still:night": "remotion still night     out/night-frame.png    --frame=540",
    "still:clock": "remotion still clock     out/clock-frame.png    --frame=600",
    "still:sun": "remotion still sun       out/sun-frame.png      --frame=600",
    "still:rhythm": "remotion still rhythm   out/rhythm-frame.png   --frame=600",
    "still:pressure": "remotion still pressure  out/pressure-frame.png --frame=540"
  },
  "dependencies": {
    "@fontsource/manrope": "^5.2.5",
    "@remotion/cli": "4.0.487",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "remotion": "4.0.487"
  },
  "devDependencies": {
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "typescript": "5.6.3"
  }
}
